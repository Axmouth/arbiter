  "query": "\n        UPDATE users\n        SET password_hash = COALESCE(password_hash, $2),\n            username = COALESCE(username, $3),\n            role = COALESCE(role, $4)\n        WHERE id = $1\n        RETURNING password_hash, username, role, id, created_at\n        ",
