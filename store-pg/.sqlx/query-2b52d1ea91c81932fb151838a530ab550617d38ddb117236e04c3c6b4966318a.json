  "query": "\n        UPDATE users\n        SET password_hash = COALESCE($2, password_hash),\n            username = COALESCE($3, username),\n            role = COALESCE($4, role)\n        WHERE id = $1\n        RETURNING password_hash, username, role, id, created_at\n        ",
